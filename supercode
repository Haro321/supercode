#!/usr/bin/env bash
# supercode — run multiple Claude Code sessions in parallel,
# each in its own isolated git worktree, all in one tmux window.

set -euo pipefail

DEFAULT_AGENTS=5
MIN_AGENTS=2
MAX_AGENTS=16
SUPERCODE_HOME="${SUPERCODE_HOME:-$HOME/.supercode}"
SUPERCODE_AGENTS="${SUPERCODE_AGENTS:-5}"
SUPERCODE_CLAUDE_ARGS="${SUPERCODE_CLAUDE_ARGS:-}"
BOOT_DELAY="${SUPERCODE_BOOT_DELAY:-3}"

# Resolve lib directory relative to the real path of this script
_sc_real="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
_sc_dir="$(cd "$(dirname "$_sc_real")" && pwd)"

if [[ -n "${SUPERCODE_LIB:-}" && -d "$SUPERCODE_LIB" ]]; then
  : # user override
elif [[ -d "$_sc_dir/lib" ]]; then
  SUPERCODE_LIB="$_sc_dir/lib"
elif [[ -d "$HOME/.local/share/supercode/lib" ]]; then
  SUPERCODE_LIB="$HOME/.local/share/supercode/lib"
else
  echo "supercode: cannot find lib/ directory" >&2
  echo "Looked in: $_sc_dir/lib, ~/.local/share/supercode/lib" >&2
  echo "Set SUPERCODE_LIB or reinstall with install.sh" >&2
  exit 1
fi

# Per-role skill files (optional — falls back to bash description if absent).
# Variable is SUPERCODE_SKILLS so it does not collide with SUPERCODE_AGENTS,
# which is the default worker count set earlier.
if [[ -n "${SUPERCODE_SKILLS:-}" && -d "$SUPERCODE_SKILLS" ]]; then
  : # user override
elif [[ -d "$_sc_dir/agents" ]]; then
  SUPERCODE_SKILLS="$_sc_dir/agents"
elif [[ -d "$HOME/.local/share/supercode/agents" ]]; then
  SUPERCODE_SKILLS="$HOME/.local/share/supercode/agents"
else
  SUPERCODE_SKILLS=""  # no skills available, that's fine
fi
export SUPERCODE_SKILLS

# Source core libraries
source "$SUPERCODE_LIB/ui.sh"
source "$SUPERCODE_LIB/git.sh"
source "$SUPERCODE_LIB/tmux_helpers.sh"
source "$SUPERCODE_LIB/agents.sh"
source "$SUPERCODE_LIB/brain.sh"
source "$SUPERCODE_LIB/session.sh"
source "$SUPERCODE_LIB/roles.sh"
source "$SUPERCODE_LIB/contracts.sh"
source "$SUPERCODE_LIB/signals.sh"

# Source all command modules
for _cmd_file in "$SUPERCODE_LIB"/commands/*.sh; do
  [[ -f "$_cmd_file" ]] && source "$_cmd_file"
done
unset _cmd_file _sc_real _sc_dir

usage() {
  cat <<EOF
${C_BOLD}supercode${C_RESET} — run multiple Claude Code sessions in parallel

${C_BOLD}USAGE${C_RESET}
  supercode                                            launch Brain session — talk to it, it plans and picks roles.
  supercode "build auth feature"                       launch Brain with context — it plans and launches agents.
  supercode --preset webapp "add login"                 skip planning — launch role-based agents immediately.
  supercode --roles backend,frontend,qa "task"         skip planning — specify exact roles to launch.
  supercode --direct "task1" ... "taskN"               one pane per task, no brain, no roles.
  supercode --snapshot stash "task1" ...               stash instead of commit before launch (commit|stash|none).
  supercode -i                                         interactive: ask how many and what tasks.
  supercode -f <file>                                  read tasks from a file (one per line, # comments ignored).

${C_BOLD}PLANNING${C_RESET}
  supercode plan "description" [--preset P]            create spec, contracts, and agent assignments (no coding)
  supercode dispatch [--preset P] [--roles a,b,c]      launch agents based on plan (reads .supercode/plan.json)
  supercode review                                     launch reviewer agent to inspect all diffs
  supercode verify [--cmd "..."]                       run build/test/lint in each worktree

${C_BOLD}MONITORING${C_RESET}
  supercode attach                                     reattach to the running session
  supercode status [--json]                            show agents, branches, dirty state, and session info
  supercode peek <N|all> [--history [LINES]]           print agent N's recent screen (or all agents)
  supercode diff <N|all>                               show files changed by each agent
  supercode logs <N|all|brain> [--tail LINES]          view per-agent captured logs

${C_BOLD}COMMUNICATION${C_RESET}
  supercode tell <N> "message"                         deliver message to agent N (multiline-safe)
  supercode broadcast "message"                        deliver message to every agent (multiline-safe)
  supercode brain [plan|status|reassign|unblock]       brain orchestrator pane / subcommands
  supercode approve <N|role>                           approve an agent's approach
  supercode reject <N|role> "reason"                   reject and redirect an agent

${C_BOLD}SAVING${C_RESET}
  supercode save [--dry-run] [--into <branch>]         commit + merge all agents into your branch
  supercode unsave                                     undo the last save
  supercode rollback                                   rewind to the pre-launch snapshot

${C_BOLD}LABELS${C_RESET}
  supercode label set <N> "short text"                 set agent N's border label
  supercode label auto                                 derive labels from pane titles
  supercode label list                                 show current labels and accent colors
  supercode label clear <N>                            remove agent N's label

${C_BOLD}CLEANUP${C_RESET}
  supercode kill                                       kill the tmux session (worktrees kept)
  supercode clean [-f|--force] [--dry-run]             kill session + remove worktrees

${C_BOLD}OWNERSHIP${C_RESET}
  supercode claim <role> <glob>                        assign file ownership to a role
  supercode claims                                     show current ownership map
  supercode conflicts                                  detect file conflicts and ownership violations
  supercode signals                                    show agent status signals (working/blocked/done)

${C_BOLD}UTILITIES${C_RESET}
  supercode doctor                                     check dependencies and environment
  supercode presets                                     list available role presets
  supercode roles                                      list available agent roles
  supercode -h | --help                                show this help

${C_BOLD}HOW IT WORKS${C_RESET}
  Each agent gets its own git worktree off the current HEAD.
  Worktrees live in:  \$SUPERCODE_HOME/<repo>/agent-N  (default ~/.supercode)
  One tmux window with tiled panes, each running \`claude\` on a worktree.

${C_BOLD}ENV${C_RESET}
  SUPERCODE_HOME           where worktrees go (default ~/.supercode)
  SUPERCODE_AGENTS         default worker count (default 5)
  SUPERCODE_CLAUDE_ARGS    extra args passed to claude (e.g. "--dangerously-skip-permissions")
  SUPERCODE_BOOT_DELAY     seconds before sending task to claude (default ${BOOT_DELAY})
  SUPERCODE_SNAPSHOT        default snapshot mode: commit|stash|none (default commit)
  SUPERCODE_LIB            override lib/ directory path

${C_BOLD}TMUX TIPS${C_RESET}
  Ctrl-b arrow    switch pane
  Ctrl-b z        zoom current pane (fullscreen toggle)
  Ctrl-b d        detach (leave running)
  Ctrl-b [        scroll mode (q to exit)
EOF
}

case "${1:-}" in
  "")                        cmd_start ;;
  -i|--interactive)          prompt_tasks_interactive ;;
  -f|--file)                 shift; read_tasks_from_file "${1:-}" ;;
  attach|a)                  cmd_attach ;;
  list|ls|status)            shift; cmd_status "$@" ;;
  save)                      shift; cmd_save "$@" ;;
  unsave)                    cmd_unsave ;;
  rollback)                  cmd_rollback ;;
  kill)                      cmd_kill ;;
  clean)                     shift; cmd_clean "$@" ;;
  brain)                     shift; cmd_brain_dispatch "$@" ;;
  peek)                      shift; cmd_peek "$@" ;;
  tell)                      shift; cmd_tell "$@" ;;
  broadcast)                 shift; cmd_broadcast "$@" ;;
  label)                     shift; cmd_label "$@" ;;
  diff)                      shift; cmd_diff "$@" ;;
  logs)                      shift; cmd_logs "$@" ;;
  plan)                      shift; cmd_plan "$@" ;;
  dispatch)                  shift; cmd_dispatch "$@" ;;
  review)                    cmd_review ;;
  verify)                    shift; cmd_verify "$@" ;;
  approve)                   shift; cmd_approve "$@" ;;
  reject)                    shift; cmd_reject "$@" ;;
  claim)                     shift; cmd_claim "$@" ;;
  claims)                    cmd_claims ;;
  conflicts)                 cmd_conflicts ;;
  signals|signal)            cmd_signals ;;
  doctor)                    cmd_doctor ;;
  presets)                   list_presets ;;
  roles)                     list_roles ;;
  state)                     shift; cmd_status "--json" ;;
  __rebalance)               shift; cmd_rebalance "$@" ;;
  -h|--help|help)            usage ;;
  *)                         cmd_start "$@" ;;
esac
